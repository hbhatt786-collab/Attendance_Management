<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.AttandanceSystem" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#1E293B</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_600</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/surface_bg</item>
        <item name="android:statusBarColor">#0F172A</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="toolbarStyle">@style/AttendanceToolbar</item>
        <item name="materialCardViewStyle">@style/AttendanceCardView</item>
    </style>

    <style name="Theme.AttandanceSystem" parent="Base.Theme.AttandanceSystem" />

    <style name="AttendanceToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">#1E293B</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">#CBD5E1</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <style name="AttendanceCardView" parent="CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">6dp</item>
    </style>
</resources>
